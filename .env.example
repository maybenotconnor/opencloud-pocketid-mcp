# =============================================================================
# OpenCloud MCP Server — Environment Configuration
# =============================================================================

# --- PocketID OIDC Auth ---
POCKETID_CONFIG_URL=https://id.example.com/.well-known/openid-configuration
POCKETID_CLIENT_ID=your-client-id
POCKETID_CLIENT_SECRET=your-client-secret

# --- MCP Server ---
MCP_BASE_URL=https://mcp.example.com
MCP_PORT=8000

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SIGNING_KEY=change-me-to-a-random-secret

# --- OpenCloud Instance ---
OPENCLOUD_URL=https://opencloud.example.com
OPENCLOUD_USERNAME=service-account
OPENCLOUD_PASSWORD=service-account-password

# --- Optional ---
# DEFAULT_TIMEZONE=America/New_York

# Optional URL overrides (derived from OPENCLOUD_URL if not set):
# WEBDAV_URL=https://cloud.example.com/remote.php/webdav
# CALDAV_URL=https://cloud.example.com/.well-known/caldav
# CARDDAV_URL=https://cloud.example.com/.well-known/carddav
